<Window x:Class="Bazy_danych_Projekt.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logowanie i Rejestracja" Width="740" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" Background="#FAFAF8" FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEWA STRONA: LOGOWANIE -->
        <StackPanel Grid.Column="0" Margin="20">
            <TextBlock Text="Zaloguj się" FontFamily="Georgia" FontSize="22" FontStyle="Italic" Foreground="#1A1A18" Margin="0,0,0,20"/>

            <TextBlock Text="Email" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Email}" Padding="5" Margin="0,0,0,15"/>

            <TextBlock Text="Hasło" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Haslo}" Padding="5" Margin="0,0,0,25"/>

            <Button Content="ZALOGUJ" Command="{Binding ZalogujCommand}" 
                    Background="#C0392B" Foreground="White" BorderThickness="0" Padding="10" FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>

        <!-- LINIA ODDZIELAJĄCA -->
        <Border Grid.Column="1" Background="#E8E6DF" Margin="0,20"/>

        <!-- PRAWA STRONA: REJESTRACJA -->
        <StackPanel Grid.Column="2" Margin="20">
            <TextBlock Text="Zarejestruj się" FontFamily="Georgia" FontSize="22" FontStyle="Italic" Foreground="#1A1A18" Margin="0,0,0,15"/>

            <!-- KAFELKI WYBORU KONTA -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 1 UŻYTKOWNIK -->
                <Button Grid.Column="0" Command="{Binding UstawRoleCommand}" CommandParameter="Uzytkownik"
                        Background="Transparent" BorderBrush="#CCCAC0" BorderThickness="1" Cursor="Hand" Height="70">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Adoptujący" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="#1A1A18"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 2 SCHRONISKO -->
                <Button Grid.Column="2" Command="{Binding UstawRoleCommand}" CommandParameter="Schronisko"
                        Background="Transparent" BorderBrush="#CCCAC0" BorderThickness="1" Cursor="Hand" Height="70">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="🏡" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Schronisko" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="#1A1A18"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- POLA WSPÓLNE -->
            <TextBlock Text="Imię / Nazwa schroniska" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
            <TextBox Text="{Binding RejImie}" Padding="5" Margin="0,0,0,15"/>

            <TextBlock Text="Email" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
            <TextBox Text="{Binding RejEmail}" Padding="5" Margin="0,0,0,15"/>

            <!-- POLA DYNAMICZNE: TYLKO DLA SCHRONISKA -->
            <StackPanel Visibility="{Binding CzyRejestracjaSchroniska, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Pełny adres (Miasto, Ulica)" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
                <TextBox Text="{Binding RejAdres}" Padding="5" Margin="0,0,0,15"/>

                <!-- DODANE POLA -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Kod poczt." FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding RejKodPocztowy}" Padding="5"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Telefon" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding RejTelefon}" Padding="5"/>
                    </StackPanel>
                </Grid>
                <!-- KONIEC DODANYCH PÓL -->

                <TextBlock Text="Numer WNI" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
                <TextBox Text="{Binding RejNumerWNI}" Padding="5" Margin="0,0,0,15"/>
            </StackPanel>

            <!-- WSPÓLNE HASŁO -->
            <TextBlock Text="Hasło" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
            <TextBox Text="{Binding RejHaslo}" Padding="5" Margin="0,0,0,20"/>

            <Button Content="ZAREJESTRUJ KONTO" Command="{Binding ZarejestrujCommand}" 
                    Background="#1A1A18" Foreground="White" BorderThickness="0" Padding="10" FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>