<Window x:Class="Bazy_danych_Projekt.Views.DodajZwierzeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj nowego podopiecznego" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" Background="#FAFAF8" FontFamily="Segoe UI">

    <Border Background="White" Padding="36">
        <StackPanel>
            <TextBlock FontFamily="Georgia" FontSize="22" FontStyle="Italic"
                       Foreground="#1A1A18" Text="Dodaj zwierzaka" Margin="0,0,0,20"/>
            
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Imię" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NowaNazwa}" Padding="5"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Gatunek" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NowyGatunek}" Padding="5"/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Rasa" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NowaRasa}" Padding="5"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Wiek (np. 3 lata)" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NowyWiek}" Padding="5"/>
                </StackPanel>
            </Grid>

            <!-- PŁEĆ I WAGA -->
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Płeć" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
                    <ComboBox SelectedValue="{Binding NowaPlec}" SelectedValuePath="Content" Padding="5">
                        <ComboBoxItem Content="Samiec"/>
                        <ComboBoxItem Content="Samica"/>
                    </ComboBox>
                </StackPanel>
                
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Waga (kg)" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NowaWaga}" Padding="5"/>
                </StackPanel>
            </Grid>

            <!-- ZABIEGI MEDYCZNE -->
            <TextBlock Text="Stan medyczny" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <CheckBox Content="Odrobaczony / Zaszczepiony" IsChecked="{Binding NowyCzySzczepiony}" Margin="0,0,15,0" Foreground="#1A1A18"/>
                <CheckBox Content="Wykastrowany / Wysterylizowana" IsChecked="{Binding NowyCzyKastrowany}" Foreground="#1A1A18"/>
            </StackPanel>

            <!-- OPIS -->
            <TextBlock Text="Opis i charakter" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
            <TextBox Text="{Binding NowyOpis}" Padding="5" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15"/>

            <TextBlock Text="Opłata adopcyjna (PLN)" FontSize="12" Foreground="#7A7A72" Margin="0,0,0,5"/>
            <TextBox Text="{Binding NowaCena}" Padding="5" Margin="0,0,0,25"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Command="{Binding AnulujCommand}" Foreground="#1A1A18" Height="38" Cursor="Hand" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderBrush="#CCCAC0" BorderThickness="1" CornerRadius="18">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="ANULUJ" TextElement.FontWeight="SemiBold"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="2" Command="{Binding ZapiszCommand}" Foreground="White" Height="38" Cursor="Hand" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#1A1A18" CornerRadius="18">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="DODAJ" TextElement.FontWeight="Bold"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>